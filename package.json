{"name":"skill-plan-lint","version":"0.1.0","description":"Local-first linter for reusable agent skill instructions.","type":"module","bin":{"skill-plan-lint":"./src/cli.js"},"scripts":{"test":"node --test tests/*.test.js","check":"node --check src/index.js && node --check src/cli.js","build":"mkdir -p dist && cp -R src dist/src","smoke":"node src/cli.js check fixtures/good-skill.md > /tmp/skill-plan-lint-smoke.txt"},"keywords":["agent","skill","dry-run","cli"],"license":"MIT"}
